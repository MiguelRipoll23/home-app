{
  "name": "matter-controller",
  "version": "1.0.0-alpha.1",
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "electron:build": "electron-vite build && electron-builder --publish never"
  },
  "build": {
    "appId": "com.home.app",
    "productName": "Home",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "MiguelRipoll23",
      "repo": "home-app"
    },
    "win": {
      "icon": "resources/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "artifactName": "${productName}.Setup.${version}.${ext}"
    },
    "mac": {
      "icon": "resources/icon.png",
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "icon": "resources/icon.png",
      "target": [
        "AppImage"
      ]
    }
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@matter/main": "^0.17.2",
    "electron-updater": "^7.0.0-alpha.1",
    "i18next": "^26.3.1",
    "lucide-react": "^1.18.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "sharp": "^0.35.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  },
  "allowScripts": {
    "electron@42.4.0": true,
    "esbuild@0.25.12": true,
    "electron-winstaller@5.4.0": true
  }
}
